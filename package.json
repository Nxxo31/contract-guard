{
  "name": "contract-guard",
  "version": "1.0.0",
  "description": "Detecta breaking changes en especificaciones OpenAPI 3.x para CI/CD",
  "main": "dist/index.js",
  "bin": {
    "contract-guard": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "openapi",
    "openapi3",
    "breaking-change",
    "api",
    "contract-testing",
    "ci-cd",
    "github-action",
    "semantic-versioning"
  ],
  "author": "Sebastian Zapata",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nxxo31/contract-guard.git"
  },
  "homepage": "https://github.com/Nxxo31/contract-guard#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  }
}